APP_NAME=SGFC
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/sgfc

FRONTEND_URL=http://localhost/sgfc/frontend

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=sgfc
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

SESSION_LIFETIME=120
SESSION_NAME=SGFC_SESSION

MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_TYPES=application/pdf

CORS_ALLOWED_ORIGIN=http://localhost/sgfc/frontend
CORS_ALLOW_CREDENTIALS=true

# Google reCAPTCHA v2 «No soy un robot». Deben estar las DOS claves o ninguna (sin captcha).
# Consola: https://www.google.com/recaptcha/admin
# Claves de prueba de Google (localhost / desarrollo; siempre aprueban): ver documentación reCAPTCHA.
# RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
# RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Contraseña SMTP (notificaciones por correo). Host/usuario/remitente se configuran en el panel Super Admin.
# Gmail: smtp.gmail.com · puerto 587 · TLS · usuario = correo completo.
# Use contraseña de aplicación de Google (no la de inicio de sesión si tiene 2FA).
# @outlook.com: smtp-mail.outlook.com · @soy.sena.edu.co: smtp.office365.com
# Si la contraseña tiene $ o *, use comillas: SMTP_PASSWORD="su_clave"
SMTP_PASSWORD=

STORAGE_PATH=storage
LOG_PATH=storage/logs
